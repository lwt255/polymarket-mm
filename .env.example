# Polymarket API (Required)
# Private key for signing orders (Polygon wallet)
POLYMARKET_PRIVATE_KEY=0x...

# Wallet address on Polygon
POLYMARKET_ADDRESS=0x...

# Polymarket CLOB API (Optional - defaults to production)
# POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Analytics (Optional)
# Supabase connection for trade logging
SUPABASE_CONNECTION_STRING=

# Polygon RPC (Optional - for on-chain operations)
# POLYGON_RPC_URL=https://polygon-rpc.com
