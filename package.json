{
  "name": "polymarket-mm",
  "version": "1.0.0",
  "type": "module",
  "description": "Prediction market bots for Polymarket (market making, arbitrage, rebate farming)",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "scan": "npx tsx src/scripts/live-scanner.ts",
    "test": "echo \"No tests yet\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "polymarket",
    "prediction-markets",
    "market-making",
    "arbitrage",
    "trading-bot"
  ],
  "author": "",
  "license": "ISC",
