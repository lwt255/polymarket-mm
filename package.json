    "ccxt": "^4.5.42",
    "commander": "^14.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "viem": "^2.30.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
